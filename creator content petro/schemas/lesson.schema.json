{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lesson",
  "type": "object",
  "required": [
    "title",
    "subject",
    "topic",
    "subtopic",
    "day",
    "week",
    "phase",
    "videos",
    "key_concepts",
    "questions",
    "question_source",
    "prova_2023_items",
    "pitfalls",
    "review",
    "checklist",
    "estimated_time"
  ],
  "properties": {
    "title": { "type": "string" },
    "subject": { "type": "string" },
    "topic": { "type": "string" },
    "subtopic": { "type": "string" },
    "day": { "type": "integer", "minimum": 1 },
    "week": { "type": "integer", "minimum": 1 },
    "phase": { "type": "string" },
    "videos": { "type": "array", "items": { "type": "string" } },
    "key_concepts": { "type": "array", "items": { "type": "string" } },
    "questions": { "type": "integer", "minimum": 0 },
    "question_source": { "type": "string" },
    "prova_2023_items": { "type": "array", "items": { "type": "integer" } },
    "pitfalls": { "type": "array", "items": { "type": "string" } },
    "review": { "type": "array", "items": { "type": "string" } },
    "checklist": { "type": "array", "items": { "type": "string" } },
    "estimated_time": {
      "type": "object",
      "required": ["video_min", "questions_min", "review_min", "total_min"],
      "properties": {
        "video_min": { "type": "integer", "minimum": 0 },
        "questions_min": { "type": "integer", "minimum": 0 },
        "review_min": { "type": "integer", "minimum": 0 },
        "total_min": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
